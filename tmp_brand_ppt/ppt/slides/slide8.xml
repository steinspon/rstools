Mod val="40000"/><a:lumOff val="60000"/></a:schemeClr></a:solidFill><a:ln><a:noFill/></a:ln></p:spPr><p:style><a:lnRef idx="0"><a:scrgbClr r="0" g="0" b="0"/></a:lnRef><a:fillRef idx="0"><a:scrgbClr r="0" g="0" b="0"/></a:fillRef><a:effectRef idx="0"><a:scrgbClr r="0" g="0" b="0"/></a:effectRef><a:fontRef idx="minor"><a:schemeClr val="lt1"/></a:fontRef></p:style><p:txBody><a:bodyPr rtlCol="0" anchor="ctr"/><a:lstStyle/><a:p><a:pPr algn="ctr"/><a:endParaRPr lang="en-US"/></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="2" name="Table Placeholder 1"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{E177D88D-BDB9-7177-427E-1EBE2E4E6222}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr><a:spLocks noGrp="1"/></p:cNvSpPr><p:nvPr><p:ph type="tbl" sz="quarter" idx="10"/></p:nvPr></p:nvSpPr><p:spPr><a:xfrm><a:off x="309296" y="995806"/><a:ext cx="11127185" cy="5339478"/></a:xfrm></p:spPr><p:txBody><a:bodyPr/><a:lstStyle/><a:p><a:endParaRPr lang="en-US" sz="1600" b="1" dirty="0"/></a:p><a:p><a:endParaRPr lang="en-US" sz="1600" b="1"/></a:p><a:p><a:r><a:rPr lang="en-US" sz="1600" b="1" dirty="0"/><a:t>As part of other text, presentations, word documents etc.</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" sz="1600" dirty="0"/><a:t>The future well secured.</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" sz="1600" i="1" dirty="0"><a:solidFill><a:schemeClr val="accent1"/></a:solidFill></a:rPr><a:t>Only the first word is capitalized. </a:t></a:r></a:p><a:p><a:endParaRPr lang="en-US" sz="1600"/></a:p><a:p><a:r><a:rPr lang="en-US" sz="1600" b="1" dirty="0"/><a:t>Stand alone in title / design / walls / roll-ups etc.</a:t></a:r></a:p><a:p><a:endParaRPr lang="en-US" sz="1600" dirty="0"/></a:p><a:p><a:r><a:rPr lang="en-US" sz="1600" dirty="0"/><a:t>The Future Well Secured</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" sz="1600" i="1" dirty="0"><a:solidFill><a:schemeClr val="accent1"/></a:solidFill></a:rPr><a:t>We capitalize each word for visual impact.</a:t></a:r></a:p><a:p><a:endParaRPr lang="en-US" sz="1600" i="1" dirty="0"><a:solidFill><a:schemeClr val="accent1"/></a:solidFill></a:endParaRPr></a:p><a:p><a:r><a:rPr lang="en-US" sz="1600" b="1" dirty="0"><a:solidFill><a:schemeClr val="tx1"/></a:solidFill></a:rPr><a:t>Please note the vision should always be written either in one line or each word below each other. </a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" sz="1600" b="1" dirty="0"><a:solidFill><a:schemeClr val="tx1"/></a:solidFill></a:rPr><a:t>The sentence should NOT be cut over 2 lines, unless there is no other option design-wise. </a:t></a:r><a:endParaRPr lang="en-US" b="1" dirty="0"><a:solidFill><a:schemeClr val="tx1"/></a:solidFill></a:endParaRPr></a:p><a:p><a:r><a:rPr lang="en-US" sz="1600" b="1" dirty="0"><a:solidFill><a:schemeClr val="tx1"/></a:solidFill></a:rPr><a:t>This due to that we lose the play on words of the sentence if we cut it over 2 lines.</a:t></a:r><a:endParaRPr lang="en-US" b="1"><a:solidFill><a:schemeClr val="tx1"/></a:solidFill></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="3" name="Title 2"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{16252B74-C6CD-BE90-2524-9BB97FD5F74D}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr><a:spLocks noGrp="1"/></p:cNvSpPr><p:nvPr><p:ph type="title"/></p:nvPr></p:nvSpPr><p:spPr/><p:txBody><a:bodyPr/><a:lstStyle/><a:p><a:r><a:rPr lang="en-GB" sz="4000" dirty="0"><a:solidFill><a:schemeClr val="accent1"><a:lumMod val="90000"/></a:schemeClr></a:solidFill></a:rPr><a:t>Usage of the vision</a:t></a:r><a:endParaRPr lang="en-GB" dirty="0"><a:solidFill><a:schemeClr val="accent1"><a:lumMod val="90000"/></a:schemeClr></a:solidFill></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="9" name="TextBox 8"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creatio